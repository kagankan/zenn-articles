{
  "rules": {
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": {
        "space": "always"
      }
    },
    "preset-ja-technical-writing": {
      "no-exclamation-question-mark": false,
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "ですます",
        "preferInList": "",
        "strict": false
      },
      "ja-no-successive-word": {
        "allow": [
          "…"
        ]
      }
    },
    "preset-japanese": true
  },
  "filters": {
    "allowlist": {
      "allow": [
        "/:::details .*/"
      ]
    }
  }
}
